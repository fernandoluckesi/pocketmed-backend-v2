NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=pocketmed_user
DB_PASSWORD=pocketmed_pass
DB_DATABASE=pocketmed

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=pocketmed-images

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Email / SMTP
# For Gmail, use an App Password (16 chars), NOT your regular account password.
# Generate at: Google Account > Security > 2-Step Verification > App passwords.
EMAIL_USER=your.account@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Sender displayed in recipient inbox
EMAIL_FROM="PocketMed <your.account@gmail.com>"

# Local dev helper:
# true  -> tries to send real emails using SMTP credentials above
# false -> does not send; logs verification/reset code in backend console
EMAIL_ENABLED=false

# If SMTP fails (bad credentials/connection), should API fallback to mock log mode?
# Recommended true in local development.
EMAIL_MOCK_FALLBACK=true
